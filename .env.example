# ---- LLM Provider Configuration ----
# Leave all blank to run fully offline with the built-in Reasoning Engine (mock).
# Set ONE of these to enable real LLM-generated answers. Groq is recommended:
# it's free, fast, and needs no credit card -- get a key at https://console.groq.com

LLM_PROVIDER=auto           # auto | groq | anthropic | openai | ollama | mock

GROQ_API_KEY =<your groq api key>
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=<your anthropic api key>
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=<your openai api key>
OPENAI_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- Backend ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Frontend ----
API_BASE=http://localhost:8000
